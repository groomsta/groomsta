{
    "info": {
        "_postman_id": "groomsta-auth-v1",
        "name": "Groomsta Fintech Auth",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "1. Phone Login (Send OTP)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phone\": \"9876543210\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/send-otp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "send-otp"
                            ]
                        }
                    }
                },
                {
                    "name": "2. Verify OTP",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"phone\": \"9876543210\",\n    \"otp\": \"<otp_from_console>\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/verify-otp",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "verify-otp"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}