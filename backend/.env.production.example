# Production Environment Config
PORT=5000
NODE_ENV=production

# Database (AWS RDS / Supabase)
DATABASE_URL="postgresql://prod_user:secure_password@prod-db.aws.com:5432/groomsta_prod"

# Security (Generated via openssl)
JWT_SECRET="long_secure_random_string_min_64_chars"

# Razorpay (Live Keys)
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="live_secret_..."
RAZORPAY_WEBHOOK_SECRET="live_webhook_secret_..."

# Redis (Production Cache/Queue)
REDIS_HOST="prod-redis.aws.com"
REDIS_PORT=6379
REDIS_PASSWORD="secure_redis_password"

# Notifications (Live APIs)
SMS_PROVIDER_KEY="twillio_live_..."
EMAIL_PROVIDER_KEY="sendgrid_live_..."
