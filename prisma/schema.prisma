  referrerCredited     Boolean  @default(false) @map("referrer_credited")
  refereeCredited      Boolean  @default(false) @map("referee_credited")
  createdAt            DateTime @default(now()) @map("created_at")
  referee              User     @relation("Referee", fields: [refereeUserId], references: [id])
  referrer             User     @relation("Referrer", fields: [referrerUserId], references: [id])

  @@index([referrerUserId])
  @@index([refereeUserId])
  @@map("referrals")
}

model UserReferralCode {
